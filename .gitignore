# OS files
.DS_Store
Thumbs.db

# Sensitive files — NEVER commit
credentials/accounts.md
credentials/api_keys.md
credentials/oauth.md

# App passwords and secrets
*.env
*.secret

# Claude local settings
.claude/

# Evidence files — engagement-specific, regenerated per engagement
evidence/screenshots/*.png
evidence/http_logs/*.txt
evidence/http-logs/*.jsonl
evidence/payload_results/*.json

# Generated reports — engagement-specific
reports/findings/**/*.md
reports/findings/*.md
!reports/findings/.gitkeep
reports/emails/F-*_email.*
reports/*.html

# Python
__pycache__/
*.pyc
*.pyo

# Logs (engagement-specific)
logs/engagement.log
logs/agent_execution.log
logs/agent_status.json
